{
  "name": "ai-extension",
  "displayName": "AI Extension",
  "description": "AI Extension prototype",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished", "onView:aiChatPanel"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-chat",
          "title": "AI Extension",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ai-chat": [
        {
          "type": "webview",
          "id": "aiChatPanel",
          "name": "AI Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "aiChat.acceptOneToken",
        "title": "AI Extension: Accept One Word/Token"
      },
      {
        "command": "aiChat.acceptNextLine",
        "title": "AI Extension: Accept Next Line"
      },
      {
        "command": "aiChat.acceptAll",
        "title": "AI Extension: Accept Whole Block"
      },
      {
        "command": "aiChat.rejectPreview",
        "title": "AI Extension: Reject Preview"
      }
    ],
    "keybindings": [
      {
        "command": "aiChat.acceptOneToken",
        "key": "ctrl+shift+right",
        "when": "aiChatPreviewActive && editorTextFocus"
      },
      {
        "command": "aiChat.acceptNextLine",
        "key": "ctrl+shift+down",
        "when": "aiChatPreviewActive && editorTextFocus"
      },
      {
        "command": "aiChat.acceptAll",
        "key": "tab",
        "when": "aiChatPreviewActive && editorTextFocus"
      },
      {
        "command": "aiChat.rejectPreview",
        "key": "escape",
        "when": "aiChatPreviewActive && editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd webview-ui && npm run build",
    "install:all": "npm install && cd webview-ui && npm install",
    "vscode:prepublish": "npm run compile && npm run build:webview"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
